<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Personaalne Treener</title>
    <link rel="icon" href="img/icons/logo-icon.png" type="image/x-icon">

    <!--Bootstrap Styles-->
    <link href="css/bootstrap.css" rel="stylesheet">
    <!--    Custom styles-->
    <link rel="stylesheet" href="css/general.css">
    <link rel="stylesheet" href="css/tracker/tracker.css">
    <!--    Chart.js-->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
</head>
<body class="bg-body-dark">

<div class="modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form class="login-form" action="">
            <div class="modal-header bg-body-dark">
                <h5 class="modal-title">Please login to continue...</h5>
            </div>
            <div class="modal-body text-black">
                    <label for="login-mail">Email</label>
                    <input id="login-mail" name="login-mail" type="email">
                    <label for="login-pass">Password</label>
                    <input id="login-pass" name="login-pass" type="text">
            </div>
            <div class="modal-footer bg-body-dark">
                <p class="login-response"></p>
                <button type="submit" class="btn btn-primary">Login</button>
            </div>
            </form>
        </div>
    </div>
</div>

    <main class="flex flex-row">
        <div class="left-block">
            <div class="main-window">
                <nav class="navbar navbar-expand-lg bg-body-yellow">
                    <div class="container-fluid">
                        <a class="navbar-brand" href="#">
                            <img src="img/logos/arm.png" alt="Bootstrap" width="80" height='35'>
                        </a>
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="collapse navbar-collapse bg-body-yellow" id="navbarNav">
                            <ul class="navbar-nav">
                                <li class="nav-item">
                                    <a class="nav-link active" aria-current="page" href="#">Home</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#">Features</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#">Pricing</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link disabled" aria-disabled="true">Disabled</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </nav>
                <div class="tab-content">
                    <%- include('tracker-sections/weekly-body-form.ejs')%>
                </div>
            </div>

            <div class="bottom-sections flex flex-row">

                <%- include('tracker-sections/bottom-block.ejs')%>

            </div>

        </div>
        <div class="right-block">

            <%- include('tracker-sections/right-block.ejs')%>

        </div>
    </main>

    <script src="js/bootstrap.min.js"></script>
    <script src="js/tracker.js"></script>
    <script src="js/tracker-body-graphs.js"></script>
</body>
</html>