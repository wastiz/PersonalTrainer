<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Personaalne Treener</title>
    <link rel="icon" href="img/icons/logo-icon.png" type="image/x-icon">

    <!--Bootstrap Styles-->
    <link href="css/bootstrap.css" rel="stylesheet">
    <link rel="stylesheet" href="css/general.css">
    <link rel="stylesheet" href="css/tracker/tracker.css">
</head>
<body class="bg-body-dark">
    <main class="flex flex-row">
        <div class="left-block">
            <div class="main-window">
                <nav class="navbar navbar-expand-lg bg-body-yellow">
                    <div class="container-fluid">
                        <a class="navbar-brand" href="#">
                            <img src="img/logos/arm.png" alt="Bootstrap" width="80" height='35'>
                        </a>
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="collapse navbar-collapse bg-body-yellow" id="navbarNav">
                            <ul class="navbar-nav">
                                <li class="nav-item">
                                    <a class="nav-link active" aria-current="page" href="#">Home</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#">Features</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#">Pricing</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link disabled" aria-disabled="true">Disabled</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </nav>
                <div class="tab-content">
                    <%- include('tracker-sections/weekly-form.ejs')%>
                </div>
            </div>

            <div class="bottom-sections flex flex-row">

                <%- include('tracker-sections/bottom-block.ejs')%>

            </div>

        </div>
        <div class="right-block">

            <%- include('tracker-sections/right-block.ejs')%>

        </div>
    </main>

    <script src="js/bootstrap.min.js"></script>
    <script src="js/tracker.js"></script>
</body>
</html>