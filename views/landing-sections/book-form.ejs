<section id="personal-training" class="flex flex-row">
    <!-- Collage -->
    <div class="collage-container">
        <img src="img/Picture/bookleftdown.jpg" alt="">
        <img src="img/Picture/bookleftdown.jpg" alt="">
        <img src="img/Picture/bookleftdown.jpg" alt="">
    </div>

    <!--Form-->
    <div class="book-form flex flex-center flex-column">
        <h2>Tule Trenni!</h2>
        <h5>Vaata lähim aeg, millal saaksid tulla trenni.</h5>
        <form class='mb-3'>
            <div class="mb-3">
                <label for="name" class="form-label">Nimi</label>
                <input type="email" class="form-control" id="name" placeholder="Siseta oma nimi...">
            </div>
            <div class="mb-3">
                <label for="exampleInputEmail1" class="form-label">Email</label>
                <input type="email" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp" placeholder="Siseta oma email...">
            </div>
            <div class="mb-3">
                <label for="telefon" class="form-label">Telefon</label>
                <input type="tel" class="form-control" id="name" placeholder="Siseta oma telefoni numbrit...">
            </div>
            <div class="mb-3">
                <label class="form-label">Treenitüüp</label>
                <select class="form-select" aria-label="Default select example">
                    <option selected>Vali treeni tüüp</option>
                    <option value="1">Toitutrenn</option>
                    <option value="2">Tavaline trenn</option>
                    <option value="3">Füüsüotrenn</option>
                </select>
            </div>
            <div class="mb-3">
                <label for="el" class="form-label">Kuupäev</label>
                <input type="text" class="form-control" id="el" placeholder="Vali kuupäev">
            </div>
            <div class="mb-3">
                <label for="el" class="form-label">Eelistatud aeg</label>
                <div>
                    <button type="button" class="btn btn-primary time-picker" data-bs-toggle="button">10-12</button>
                    <button type="button" class="btn btn-primary time-picker" data-bs-toggle="button">13-15</button>
                    <button type="button" class="btn btn-primary time-picker" data-bs-toggle="button">16-18</button>
                </div>
            </div>
            <div class="flex flex-center">
                <button type="submit" class="btn btn-primary">Saada</button>
            </div>
        </form>
    </div>

</section>