<% const bodyParts = [
    { id: 'height', name: 'Height'},
    { id: 'weight', name: 'Weight' },
    { id: 'waist', name: 'Waist' },
    { id: 'chest', name: 'Chest' },
    { id: 'shoulders', name: 'Shoulders' },
    { id: 'biceps', name: 'Biceps' },
    { id: 'forearms', name: 'Forearms' },
    { id: 'neck', name: 'Neck' },
    { id: 'hips', name: 'Hips' },
    { id: 'calves', name: 'Calves' }
]; %>

<div class="container mt-5">
    <h2>Body Measurements</h2>
    <ul class="nav nav-tabs" id="bodyMeasurementTabs" role="tablist">
        <% bodyParts.forEach((part, index) => { %>
            <li class="nav-item" role="presentation">
                <button class="nav-link <%= index === 0 ? 'active' : '' %>" id="<%= part.id %>-tab" data-bs-toggle="tab" data-bs-target="#<%= part.id %>" type="button" role="tab">
                    <%= part.name %>
                </button>
            </li>
        <% }) %>
    </ul>

    <div class="tab-content mt-3">
        <% bodyParts.forEach((part, index) => { %>
            <div class="tab-pane fade <%= index === 0 ? 'show active' : '' %>" id="<%= part.id %>" role="tabpanel">
                <canvas id="<%= part.id %>-chart" width="400" height="200"></canvas>
            </div>
        <% }) %>
    </div>
</div>

