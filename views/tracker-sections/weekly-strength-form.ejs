<form class='mb-3'>
    <div class="container">
        <h3 class="text-center">Weekly Strength Measurements</h3>
        <div class="row">
            <!-- Силовые упражнения -->
            <div class="col-6">
                <div class="mb-3">
                    <label for="bench-press" class="form-label">Bench Press (kg)</label>
                    <input name="bench-press" type="number" class="form-control" id="bench-press" placeholder="Enter your bench press weight...">
                </div>
                <div class="mb-3">
                    <label for="squat" class="form-label">Squat (kg)</label>
                    <input name="squat" type="number" class="form-control" id="squat" placeholder="Enter your squat weight...">
                </div>
                <div class="mb-3">
                    <label for="deadlift" class="form-label">Deadlift (kg)</label>
                    <input name="deadlift" type="number" class="form-control" id="deadlift" placeholder="Enter your deadlift weight...">
                </div>
            </div>

            <!-- Дополнительные силовые показатели -->
            <div class="col-6">
                <div class="mb-3">
                    <label for="bicep-curl" class="form-label">Bicep Curl (kg)</label>
                    <input name="bicep-curl" type="number" class="form-control" id="bicep-curl" placeholder="Enter your bicep curl weight...">
                </div>
                <div class="mb-3">
                    <label for="shoulder-press" class="form-label">Shoulder Press (kg)</label>
                    <input name="shoulder-press" type="number" class="form-control" id="shoulder-press" placeholder="Enter your shoulder press weight...">
                </div>
                <div class="mb-3">
                    <label for="pull-up" class="form-label">Pull-up (reps)</label>
                    <input name="pull-up" type="number" class="form-control" id="pull-up" placeholder="Enter your pull-up repetitions...">
                </div>
            </div>
        </div>

        <div class="flex flex-center">
            <button type="submit" class="btn btn-primary">Submit Strength Measurements</button>
        </div>
    </div>
</form>