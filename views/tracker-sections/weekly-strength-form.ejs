<form class="mb-3 weekly-strength-form">
    <div class="container">
        <h3 class="text-center">Weekly Strength Measurements</h3>
        <div class="row">
            <% const strengthExercises = [
                { id: 'bench_press_wide', label: 'Bench Press Wide (kg)', placeholder: 'Enter your bench press wide weight...' },
                { id: 'bench_press_narrow', label: 'Bench Press Narrow (kg)', placeholder: 'Enter your bench press narrow weight...' },
                { id: 'deadlift', label: 'Deadlift (kg)', placeholder: 'Enter your deadlift weight...' },
                { id: 'squats', label: 'Squats (kg)', placeholder: 'Enter your squat weight...' },
                { id: 'bicep_curl', label: 'Bicep Curl (kg)', placeholder: 'Enter your bicep curl weight...' },
                { id: 'bent_over_one_arm_row', label: 'Bent Over One Arm Row (kg)', placeholder: 'Enter your row weight...' }
            ]; %>

            <% strengthExercises.forEach((exercise, index) => { %>
                <div class="col-6">
                    <div class="mb-3">
                        <label for="<%= exercise.id %>" class="form-label"><%= exercise.label %></label>
                        <input
                                name="<%= exercise.id %>"
                                type="number"
                                class="form-control"
                                id="<%= exercise.id %>"
                                placeholder="<%= exercise.placeholder %>"
                        >
                    </div>
                </div>
            <% }) %>
        </div>

        <style>
            #strength-form-modal {
                display: none;
            }
        </style>

        <div class="flex flex-center">
            <button type="submit" class="btn btn-primary">Submit</button>
        </div>

        <div class="modal fade" id="strength-form-modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title fs-5" id="staticBackdropLabel">Modal title</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="strength-form-modal-text">Initial text...</div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</form>
