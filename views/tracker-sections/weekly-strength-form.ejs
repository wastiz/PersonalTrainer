<h2 class="text-yellow">Weekly body measurments</h2>
<form class="mb-3 weekly-strength-form">
    <div class="container">
        <h3 class="text-center">Weekly Strength Measurements</h3>
        <div class="row">
            <% const strengthExercises = [
                { id: 'bench_press_wide', label: 'Bench Press Wide (kg)', placeholder: 'Enter your bench press wide weight...' },
                { id: 'bench_press_narrow', label: 'Bench Press Narrow (kg)', placeholder: 'Enter your bench press narrow weight...' },
                { id: 'deadlift', label: 'Deadlift (kg)', placeholder: 'Enter your deadlift weight...' },
                { id: 'squats', label: 'Squats (kg)', placeholder: 'Enter your squat weight...' },
                { id: 'bicep_curl', label: 'Bicep Curl (kg)', placeholder: 'Enter your bicep curl weight...' },
                { id: 'bent_over_one_arm_row', label: 'Bent Over One Arm Row (kg)', placeholder: 'Enter your row weight...' }
            ]; %>

            <% strengthExercises.forEach((exercise) => { %>
                <div class="col-6">
                    <div class="mb-3">
                        <label for="<%= exercise.id %>" class="form-label"><%= exercise.label %></label>
                        <input
                                name="<%= exercise.id %>"
                                type="number"
                                class="form-control"
                                id="<%= exercise.id %>"
                                placeholder="<%= exercise.placeholder %>"
                        >
                    </div>
                </div>
            <% }) %>
        </div>

        <div class="flex flex-center">
            <button type="submit" class="btn btn-primary">Submit</button>
        </div>

    </div>
</form>
